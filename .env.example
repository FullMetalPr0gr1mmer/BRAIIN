# Braiin Station — environment template.
# Copy to `.env` (git-ignored) for local dev. For Cloudflare, PUBLIC_* go in
# wrangler vars; SECRETS go in `wrangler secret put` / dashboard / Supabase Vault.
# NEVER commit real values.

# ---- Client-safe (public, non-sensitive) ----
PUBLIC_SITE_URL="http://localhost:4321"
PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="eyJ...anon-key..."

# ---- Server, non-secret config ----
AI_DAILY_USD_CAP="5"

# ---- Server SECRETS (server-only; never client-bundled) ----
# Supavisor transaction-mode pooler URL (:6543, pgbouncer=true, prepare:false).
SUPABASE_DB_POOL_URL="postgresql://postgres.YOUR-PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
SUPABASE_SERVICE_ROLE_KEY="eyJ...service-role-key... (KEEP SECRET)"
# 32-byte base64 key for envelope-encrypting lead PII (phone/email/budget).
LEAD_PII_ENC_KEY="base64:CHANGE_ME_32_BYTES"
# HMAC key for the append-only audit hash-chain (store in Supabase Vault in prod).
AUDIT_HMAC_KEY="base64:CHANGE_ME_32_BYTES"
# Bearer secret the DB trigger uses to authenticate the notify-lead Worker call.
NOTIFY_LEAD_SECRET="CHANGE_ME_RANDOM"
# Optional until the AI Style-Finder is built (Phase 4). Server-only.
ANTHROPIC_API_KEY=""
