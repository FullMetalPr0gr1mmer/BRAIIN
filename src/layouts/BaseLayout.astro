---
import type { Locale } from '@schemas/primitives';
import type { JsonLdNode } from '@/lib/seo/jsonld';
import SeoHead from '@/components/SeoHead.astro';
import ConsentBanner from '@/components/ConsentBanner.astro';
import WebVitals from '@/components/WebVitals.astro';
import ErrorReporter from '@/components/ErrorReporter.astro';
import { dir } from '@/lib/i18n';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  logicalPath: string;
  jsonLd?: JsonLdNode[];
  robots?: string;
  ogImage?: string;
}

const {
  title,
  description,
  locale,
  logicalPath,
  jsonLd = [],
  robots = 'index,follow',
  ogImage,
} = Astro.props;
const direction = dir(locale);
---

<!doctype html>
<html lang={locale} dir={direction}>
  <head>
    <SeoHead
      title={title}
      description={description}
      locale={locale}
      logicalPath={logicalPath}
      jsonLd={jsonLd}
      robots={robots}
      {...ogImage ? { ogImage } : {}}
    />
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <slot />
    <ConsentBanner />
    <WebVitals />
    <ErrorReporter />
  </body>
</html>
