---
import type { Locale } from '@schemas/primitives';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { buildBreadcrumbSchema } from '@/lib/seo/jsonld';
import { localizedPath } from '@/lib/i18n';
import { PUBLIC_SITE_URL } from 'astro:env/client';
import type { PortfolioRow } from '@/lib/data/portfolio';

interface Props {
  locale: Locale;
  items: PortfolioRow[];
}

const { locale, items } = Astro.props;

const STR = {
  en: {
    title: 'Portfolio',
    intro: 'Selected work from across our fourteen creative services.',
    empty: 'Case studies will appear here once published.',
    home: 'Home',
  },
  ar: {
    title: 'أعمالنا',
    intro: 'مختارات من أعمالنا عبر خدماتنا الإبداعية الأربع عشرة.',
    empty: 'ستظهر دراسات الحالة هنا بعد نشرها.',
    home: 'الرئيسية',
  },
}[locale];

const base = PUBLIC_SITE_URL.replace(/\/$/, '');
const breadcrumb = buildBreadcrumbSchema([
  { name: STR.home, url: base + localizedPath('/', locale) },
  { name: STR.title, url: base + localizedPath('/portfolio', locale) },
]);
---

<BaseLayout
  title={`${STR.title} — Braiin Station`}
  description={STR.intro}
  locale={locale}
  logicalPath="/portfolio"
  jsonLd={[breadcrumb]}
>
  <main class="container">
    <h1>{STR.title}</h1>
    <p class="lead">{STR.intro}</p>
    {
      items.length === 0 ? (
        <p class="notice">{STR.empty}</p>
      ) : (
        <ul class="service-grid">
          {items.map((p) => (
            <li class="service-card">
              <a href={localizedPath(`/portfolio/${p.slug}`, locale)}>
                <h2>{p.title[locale] ?? p.title.en ?? p.slug}</h2>
                {p.summary ? <p>{p.summary[locale] ?? p.summary.en ?? ''}</p> : null}
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </main>
</BaseLayout>
