---
// First-party client error reporter (operational; consent-independent — the server
// PII-scrubs before persisting). Beacons window errors + unhandled rejections to
// /api/clientlog. The Sentry SDK + same-origin tunnel plug in at provisioning.
---

<script>
  function report(level: string, message: unknown, source?: string, line?: number, col?: number) {
    try {
      navigator.sendBeacon(
        '/api/clientlog',
        JSON.stringify({
          level,
          message: String(message).slice(0, 2000),
          source,
          line,
          col,
          path: location.pathname,
        }),
      );
    } catch {
      /* never let logging throw */
    }
  }

  window.addEventListener('error', (e) =>
    report('error', e.message, e.filename, e.lineno, e.colno),
  );
  window.addEventListener('unhandledrejection', (e) => {
    const reason = e.reason;
    const msg = reason && reason.message ? reason.message : String(reason);
    report('error', 'unhandledrejection: ' + msg, location.pathname);
  });
</script>
