---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionRenderer from '@/components/SectionRenderer.astro';
import { DEFAULT_HOME_SECTIONS } from '@/lib/sections/types';
import { buildOrganizationSchema, buildWebSiteSchema } from '@/lib/seo/jsonld';
import { PUBLIC_SITE_URL } from 'astro:env/client';

const jsonLd = [buildOrganizationSchema(PUBLIC_SITE_URL), buildWebSiteSchema(PUBLIC_SITE_URL)];
Astro.response.headers.set(
  'Cache-Control',
  'public, s-maxage=31536000, stale-while-revalidate=86400',
);
Astro.response.headers.set('Cache-Tag', 'tenant:default,route:home,locale:ar');
---

<BaseLayout
  title="بريّن ستيشن — وكالة إبداعية"
  description="وكالة إبداعية ثنائية اللغة: الهوية، الموشن، الفيديو، الويب، وتحسين محركات البحث وأكثر. 14 خدمة في استوديو واحد."
  locale="ar"
  logicalPath="/"
  jsonLd={jsonLd}
>
  <main>
    <SectionRenderer locale="ar" sections={DEFAULT_HOME_SECTIONS} />
  </main>
</BaseLayout>
