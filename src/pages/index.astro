---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionRenderer from '@/components/SectionRenderer.astro';
import { DEFAULT_HOME_SECTIONS } from '@/lib/sections/types';
import { buildOrganizationSchema, buildWebSiteSchema } from '@/lib/seo/jsonld';
import { PUBLIC_SITE_URL } from 'astro:env/client';

// Tier A. Home is composed from CMS sections (default composition until page_sections
// is authored in Phase 3). Publish purges the `route:home` cache tag.
const jsonLd = [buildOrganizationSchema(PUBLIC_SITE_URL), buildWebSiteSchema(PUBLIC_SITE_URL)];
Astro.response.headers.set(
  'Cache-Control',
  'public, s-maxage=31536000, stale-while-revalidate=86400',
);
Astro.response.headers.set('Cache-Tag', 'tenant:default,route:home,locale:en');
---

<BaseLayout
  title="Braiin Station — Creative Agency"
  description="A bilingual creative agency: branding, motion, video, web, SEO and more. 14 services, one studio."
  locale="en"
  logicalPath="/"
  jsonLd={jsonLd}
>
  <main>
    <SectionRenderer locale="en" sections={DEFAULT_HOME_SECTIONS} />
  </main>
</BaseLayout>
