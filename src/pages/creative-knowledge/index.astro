---
import BlogIndex from '@/components/BlogIndex.astro';
import { getPublishedPosts } from '@/lib/data/blog';

// Tier A (indexable, edge-cached SSR). Publish purges the `blog:all` cache tag.
const posts = await getPublishedPosts();
Astro.response.headers.set(
  'Cache-Control',
  'public, s-maxage=31536000, stale-while-revalidate=86400',
);
Astro.response.headers.set('Cache-Tag', 'tenant:default,route:blog,blog:all,locale:en');
---

<BlogIndex locale="en" posts={posts} />
