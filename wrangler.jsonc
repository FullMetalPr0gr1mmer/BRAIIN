{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "braiin-station",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],
  // NOTE (adapter v14): no `main` here. The Cloudflare Vite plugin resolves the worker
  // entry during the build and errors if `main` points at a not-yet-emitted output file
  // (the old v12 value was "./dist/_worker.js/index.js").
  "assets": {
    // Astro 7 splits output into dist/client (public) + dist/server (worker, wrangler.json
    // AND .dev.vars containing real env values). Pointing at ./dist would serve
    // dist/server/.dev.vars over HTTP under `wrangler dev` (the perf-seo-a11y workflow).
    "directory": "./dist/client",
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": true,
  },
  // Image transforms (astro adapter imageService: 'cloudflare-binding').
  "images": {
    "binding": "IMAGES",
  },
  // Astro session storage. Create with: wrangler kv namespace create SESSION
  // then paste the id below (and a preview_id for `wrangler dev`).
  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "REPLACE_WITH_SESSION_KV_ID",
      "preview_id": "REPLACE_WITH_SESSION_KV_PREVIEW_ID",
    },
  ],
  // NOTE: secrets (SUPABASE_SERVICE_ROLE_KEY, LEAD_PII_ENC_KEY, AUDIT_HMAC_KEY,
  // NOTIFY_LEAD_SECRET, ANTHROPIC_API_KEY) are set via `wrangler secret put <NAME>`
  // or the Cloudflare dashboard — NEVER committed here.
}
